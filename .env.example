# Copy to `.env.local` and adjust values. Next.js loads `.env.local` automatically.
# https://nextjs.org/docs/app/guides/environment-variables

# --- Public (exposed to the browser if prefixed NEXT_PUBLIC_) ---

# Canonical site URL for metadata (Open Graph, etc.). In dev, localhost is used if unset.
# NEXT_PUBLIC_SITE_URL=https://www.chcstemple.org

# Optional: preview strip text at the top of the site.
# NEXT_PUBLIC_PREVIEW_BANNER=

# Optional: Google Maps embed `src` (Share → Embed a map).
# NEXT_PUBLIC_GOOGLE_MAPS_EMBED_SRC=

# --- Server-only (never prefix secrets with NEXT_PUBLIC_) ---

# Dev only: when you open the site from another device (e.g. http://192.168.x.x:3000), add that
# host/IP here so Next.js allows HMR / _next assets. Comma-separated. Restart `npm run dev` after change.
# NEXT_ALLOWED_DEV_ORIGINS=192.168.0.70

# --- Committee admin (sign in at /admin/login, then hub at /admin) ---
# Recommended: one PIN for both events + memberships (edit). Optional: keep separate PINs below.
# CHCS_ADMIN_PIN=
#
# Separate PINs still work on the same /admin/login form if you prefer:
# MEMBERSHIPS_VIEW_PIN — read-only: browse and export, no add/edit/delete.
# MEMBERSHIPS_ADMIN_PIN — full memberships access; on unified /admin/login also unlocks events (same browser session).
# In development, if VIEW is unset the login accepts PIN: view; if ADMIN is unset: dev
# MEMBERSHIPS_VIEW_PIN=
# MEMBERSHIPS_ADMIN_PIN=
#
# /admin/events — events-only access if you do not use CHCS_ADMIN_PIN
# In development, if unset the login accepts PIN: events
# EVENTS_ADMIN_PIN=
#
# Unified login dev default for CHCS_ADMIN_PIN (when env unset): chcs

# --- Supabase (browser client; used by /supabase-test) ---

# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key

# Server-only: required for /admin/events and /admin/memberships to read/write Supabase tables
# and upload event images to Storage. Never expose this in the browser.
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional: when using Supabase for memberships, encrypt postal fields / phone / email at rest (no in-app reminder).
# 32-byte key — generate with: openssl rand -base64 32
# Set on the server (e.g. .env.local + restart dev, or Netlify env + redeploy). Decryption only in server actions after admin login.
# MEMBERSHIP_PII_ENCRYPTION_KEY=

# Optional: override default bucket name `event-images` (must exist in Supabase Storage)
# SUPABASE_EVENTS_STORAGE_BUCKET=event-images
